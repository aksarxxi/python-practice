    "class Animal:\n",
    "    def walk():\n",
    "        return \"Walking!\"\n",
    "    \n",
    "class Dog(Animal):\n",
    "    def __init__(self, name, age):\n",
    "        self.name = name\n",
    "        self.age = age\n",
    "    \n",
    "    def bark():\n",
    "        return \"Wooff!\"\n",
    "    \n",
    "roger = Dog(Roger, 80)\n"
